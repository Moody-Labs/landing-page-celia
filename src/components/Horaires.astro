---
interface DaySchedule {
  day: string
  hours: string
  opens?: string
  closes?: string
  active: boolean
}

const schedule: DaySchedule[] = [
  { day: 'Lundi', hours: '14h30 — 19h00', opens: '14:30', closes: '19:00', active: true },
  { day: 'Mardi', hours: '14h30 — 19h00', opens: '14:30', closes: '19:00', active: true },
  { day: 'Mercredi', hours: '14h30 — 19h00', opens: '14:30', closes: '19:00', active: true },
  { day: 'Jeudi', hours: '14h30 — 19h00', opens: '14:30', closes: '19:00', active: true },
  { day: 'Vendredi', hours: '14h30 — 19h00', opens: '14:30', closes: '19:00', active: true },
  { day: 'Samedi', hours: '9h00 — 18h00', opens: '09:00', closes: '18:00', active: true },
  { day: 'Dimanche', hours: 'Fermé', active: false },
]
---

<section class="py-24 bg-surface" id="horaires">
  <div class="max-w-7xl mx-auto px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">

      <div class="lg:col-span-5" data-animate="fade-right">
        <span class="text-secondary font-label text-xs tracking-[0.3em] uppercase mb-4 block font-semibold">
          INFOS PRATIQUES
        </span>
        <h2 class="font-headline text-4xl md:text-5xl text-on-surface mb-8 leading-tight">
          Horaires <span class="italic">&amp; accès</span>
        </h2>
        <p class="text-lg text-on-surface-variant leading-relaxed mb-10">
          Je reçois uniquement sur rendez-vous pour vous garantir un créneau dédié,
          sans attente. N'hésitez pas à me contacter pour toute question ou
          pour réserver votre prochaine séance.
        </p>

        <address class="not-italic space-y-6">
          <div class="flex items-start gap-4">
            <span class="material-symbols-outlined text-secondary text-2xl mt-0.5" aria-label="Localisation">location_on</span>
            <div>
              <p class="font-bold text-on-surface mb-1">Adresse</p>
              <a
                href="https://www.google.com/maps/dir/?api=1&destination=Rte+de+Grangeon,+07260+Rosières"
                target="_blank"
                rel="noopener noreferrer"
                class="text-primary text-sm font-medium hover:underline underline-offset-4 inline-flex items-center gap-1.5"
              >
                Rte de Grangeon, 07260 Rosières, Ardèche
                <span class="material-symbols-outlined text-base">arrow_outward</span>
              </a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <span class="material-symbols-outlined text-secondary text-2xl mt-0.5" aria-label="Accès">directions_car</span>
            <div>
              <p class="font-bold text-on-surface mb-1">Accès</p>
              <p class="text-on-surface-variant text-sm leading-relaxed">
                Parking gratuit à proximité. Institut situé au calme, facile d'accès.
              </p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <span class="material-symbols-outlined text-secondary text-2xl mt-0.5" aria-label="Accessibilité">accessibility_new</span>
            <div>
              <p class="font-bold text-on-surface mb-1">Accessibilité</p>
              <p class="text-on-surface-variant text-sm leading-relaxed">
                L'institut n'est malheureusement pas accessible aux personnes à mobilité réduite.
                N'hésitez pas à me contacter pour en discuter.
              </p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <span class="material-symbols-outlined text-secondary text-2xl mt-0.5" aria-label="Contact">chat</span>
            <div>
              <p class="font-bold text-on-surface mb-1">Contact</p>
              <a
                href="https://www.instagram.com/celiac_techniciennedecils07260/"
                target="_blank"
                rel="noopener noreferrer"
                class="text-primary text-sm font-medium hover:underline underline-offset-4 inline-flex items-center gap-1.5"
              >
                Me contacter sur Instagram
                <span class="material-symbols-outlined text-base">arrow_outward</span>
              </a>
              <a
                href="tel:+33648362240"
                class="text-primary text-sm font-medium hover:underline underline-offset-4 inline-flex items-center gap-1.5"
              >
                Me contacter par téléphone : 06 48 36 22 40
                <span class="material-symbols-outlined text-base">phone</span>
              </a>
            </div>
          </div>
        </address>
      </div>

      <div class="lg:col-span-7" data-animate="fade-left">
        <div class="bg-surface-container-lowest rounded-xl border border-outline-variant/10 overflow-hidden shadow-xl shadow-on-surface/5">
          <div class="bg-surface-container p-6 flex items-center gap-3">
            <span class="material-symbols-outlined text-secondary text-xl" aria-label="Horaires">schedule</span>
            <h3 class="font-headline text-xl text-on-surface">Horaires d'ouverture</h3>
          </div>

          <div class="divide-y divide-outline-variant/10">
            {schedule.map((slot) => (
              <div class:list={[
                'flex items-center justify-between px-6 py-5 transition-colors',
                slot.active ? 'hover:bg-surface-container-low' : 'bg-surface-dim/30',
              ]}>
                <span class:list={[
                  'font-medium',
                  slot.active ? 'text-on-surface' : 'text-outline',
                ]}>
                  {slot.day}
                </span>
                <span class:list={[
                  'text-sm tracking-wide',
                  slot.active ? 'text-on-surface-variant font-medium' : 'text-outline italic',
                ]}>
                  {slot.opens && slot.closes ? (
                    <Fragment>
                      <time datetime={slot.opens}>{slot.hours.split(' — ')[0]}</time> — <time datetime={slot.closes}>{slot.hours.split(' — ')[1]}</time>
                    </Fragment>
                  ) : (
                    slot.hours
                  )}
                </span>
              </div>
            ))}
          </div>

          <div class="px-6 py-5 bg-secondary/5 flex items-start gap-3">
            <span class="material-symbols-outlined text-secondary text-lg mt-0.5" aria-label="Information">info</span>
            <p class="text-sm text-on-surface-variant leading-relaxed">
              <strong class="text-on-surface font-medium">Sur rendez-vous uniquement.</strong>
              Les créneaux sont limités pour garantir un service personnalisé.
              Pensez à réserver à l'avance.
            </p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
