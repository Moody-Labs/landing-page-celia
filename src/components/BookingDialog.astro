---
import { SEO } from '../data/seo'

const { phone, phoneDisplay } = SEO.business
---

<dialog
  id="booking-dialog"
  class="bg-transparent p-0 backdrop:bg-black/50 backdrop:backdrop-blur-sm m-auto w-full max-w-sm"
  aria-labelledby="booking-dialog-title"
>
  <div class="bg-surface rounded-2xl p-6 shadow-2xl mx-4">
    <div class="flex items-start justify-between mb-2">
      <h3
        id="booking-dialog-title"
        class="font-headline text-2xl text-on-surface"
      >
        Prendre rendez-vous
      </h3>
      <button
        type="button"
        data-booking-close
        aria-label="Fermer"
        class="text-on-surface-variant hover:text-on-surface transition-colors -mr-1 -mt-1 p-1"
      >
        <span class="material-symbols-outlined">close</span>
      </button>
    </div>

    <p class="text-sm text-on-surface-variant mb-6">
      Choisissez votre moyen de contact préféré.
    </p>

    <div class="flex flex-col gap-3">
      <a
        href={`tel:${phone}`}
        class="hero-gradient text-on-primary px-6 py-4 rounded-full font-bold text-base shadow-lg shadow-primary/20 active:scale-95 transition-all duration-300 inline-flex items-center justify-center gap-2"
      >
        <span class="material-symbols-outlined">call</span>
        Appeler {phoneDisplay}
      </a>

      <a
        href={`sms:${phone}`}
        class="px-6 py-4 rounded-full font-bold text-base border border-outline-variant/40 text-primary hover:bg-surface-container-low active:scale-95 transition-all duration-300 inline-flex items-center justify-center gap-2"
      >
        <span class="material-symbols-outlined">sms</span>
        Envoyer un SMS
      </a>
    </div>
  </div>
</dialog>

<script>
  const dialog = document.getElementById('booking-dialog') as HTMLDialogElement | null

  if (dialog) {
    document.querySelectorAll('[data-booking-cta]').forEach((el) => {
      el.addEventListener('click', (event) => {
        event.preventDefault()
        dialog.showModal()
      })
    })

    dialog.querySelectorAll('[data-booking-close]').forEach((el) => {
      el.addEventListener('click', () => dialog.close())
    })

    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) dialog.close()
    })
  }
</script>
