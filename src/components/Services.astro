---
interface PoseComplete {
  title: string;
  price: string;
  description: string;
  icon: string;
  features: string[];
}

interface RemplissageRow {
  type: string;
  sem2: string;
  sem3: string;
  sem4: string;
}

const poses: PoseComplete[] = [
  {
    title: "Cil à Cil",
    price: "70€",
    icon: "auto_awesome",
    description:
      "La méthode classique pour un effet naturel. Une extension est appliquée sur chaque cil naturel pour apporter longueur et courbure.",
    features: [
      "Effet naturel garanti",
      "Remplissage conseillé toutes les 3 semaines (env. 2h)",
      "Compter environ 3h pour la pose complète",
    ],
  },
  {
    title: "Mixte",
    price: "80€",
    icon: "flare",
    description:
      "Le jeu d'équilibre entre légéreté du cil à cil et la profondeur du volume russe. Un mélange pour un regard sophistiqué et harmonieux.",
    features: [
      "Résultat sophistiqué et naturel",
      "Remplissage conseillé toutes les 2 semaines (env. 2h)",
      "Compter environ 3h pour la pose complète",
    ],
  },
  {
    title: "Volume Russe",
    price: "90€",
    icon: "diversity_2",
    description:
      "Plusieurs extensions ultra-fines appliquées sur un seul cil naturel pour créer un éventail, offrant une densité incomparable.",
    features: [
      "Pour un regard profond",
      "Technique respectueuse du cil naturel",
      "Compter environ 3h pour la pose complète",
    ],
  },
];

const remplissages: RemplissageRow[] = [
  { type: "Cil à cil", sem2: "25€", sem3: "35€", sem4: "45€" },
  { type: "Mixte", sem2: "30€", sem3: "40€", sem4: "50€" },
  { type: "Volume Russe", sem2: "35€", sem3: "45€", sem4: "55€" },
];
---

<section class="py-24 bg-surface-container-low" id="prestations">
  <div class="max-w-7xl mx-auto px-8">
    <div class="text-center mb-20" data-animate>
      <span
        class="text-secondary font-label text-xs tracking-[0.3em] uppercase mb-4 block"
      >
        Mes Prestations
      </span>
      <h2 class="font-headline text-4xl md:text-5xl text-on-surface mb-4">
        Tarifs Extensions de Cils
      </h2>
      <p
        class="text-on-surface-variant max-w-2xl mx-auto text-lg font-light leading-relaxed"
      >
        Des soins conçus pour sublimer votre beauté naturelle avec précision et
        délicatesse.
      </p>
    </div>

    {/* Pose Complète - Editorial Cards */}
    <div class="space-y-20 mb-32">
      {
        poses.map((pose, i) => (
          <div
            class:list={[
              "grid grid-cols-1 md:grid-cols-12 gap-8 items-center",
              i % 2 !== 0 && "md:[direction:rtl] md:[&>*]:[direction:ltr]",
            ]}
          >
            <div class="md:col-span-5">
              <div class="bg-surface-container-lowest p-10 md:p-12 rounded-xl border border-outline-variant/10 relative overflow-hidden">
                <div class="absolute top-0 left-0 w-full h-1 hero-gradient" />
                <div class="flex justify-between items-start mb-6">
                  <span class="material-symbols-outlined text-primary text-4xl">
                    {pose.icon}
                  </span>
                  <span class="text-secondary font-bold text-2xl">
                    {pose.price}
                  </span>
                </div>
                <h3 class="font-headline text-3xl text-on-surface mb-4">
                  {pose.title}
                </h3>
                <p class="text-on-surface-variant leading-relaxed mb-8">
                  {pose.description}
                </p>
                <ul class="space-y-3">
                  {pose.features.map((feat) => (
                    <li class="flex gap-3 items-start">
                      <span class="material-symbols-outlined text-secondary text-lg">
                        check_circle
                      </span>
                      <span class="text-sm text-on-surface-variant">
                        {feat}
                      </span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            <div class="md:col-span-7">
              <div
                class:list={[
                  "bg-primary/5 rounded-xl p-10 md:p-14 flex flex-col justify-center min-h-[280px]",
                  i === 0 && "bg-primary/5",
                  i === 1 && "bg-secondary/5",
                  i === 2 && "bg-tertiary/5",
                ]}
              >
                <span class="material-symbols-outlined text-5xl mb-4 opacity-20 text-primary">
                  format_quote
                </span>
                <p class="font-headline text-2xl md:text-3xl italic text-on-surface leading-snug mb-6">
                  {i === 0 &&
                    "Idéal pour celles qui souhaitent un regard souligné mais discret, parfait pour le quotidien."}
                  {i === 1 &&
                    "Le choix intermédiaire entre le cil à cil et le volume russe: un regard intensifié qui reste naturel en toute circonstance."}
                  {i === 2 &&
                    "Une densité sur mesure, du look naturel fourni au glamour intense."}
                </p>
                <div class="flex items-center gap-4">
                  <div class="w-12 h-[1px] bg-outline-variant/30" />
                  <span class="font-label text-sm text-on-surface-variant tracking-wide">
                    Pose complète
                  </span>
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    {/* Grille des Tarifs - Remplissage */}
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <h3 class="font-headline text-3xl text-on-surface mb-4">
          Grille des Remplissages
        </h3>
        <div class="w-12 h-1 bg-secondary mx-auto"></div>
      </div>

      <div
        class="bg-surface-container-lowest rounded-xl shadow-xl shadow-on-surface/5 overflow-hidden"
      >
        <div
          class="grid grid-cols-[1.6fr_1fr_1fr_1fr] bg-surface-container px-4 py-4 md:px-6 md:py-6 text-[10px] md:text-xs font-label uppercase tracking-widest text-on-surface-variant"
        >
          <div>Prestation</div>
          <div class="text-center">
            <span class="sm:hidden">2 sem.</span>
            <span class="hidden sm:inline">2 semaines</span>
          </div>
          <div class="text-center">
            <span class="sm:hidden">3 sem.</span>
            <span class="hidden sm:inline">3 semaines</span>
          </div>
          <div class="text-center">
            <span class="sm:hidden">4 sem.</span>
            <span class="hidden sm:inline">4 semaines</span>
          </div>
        </div>
        <div class="divide-y divide-outline-variant/10">
          {
            remplissages.map((r) => (
              <div class="grid grid-cols-[1.6fr_1fr_1fr_1fr] px-4 py-5 md:p-6 items-center hover:bg-surface-container-low transition-colors group">
                <div class="font-headline text-base md:text-lg leading-tight group-hover:text-primary transition-colors">
                  {r.type}
                </div>
                <div class="text-center font-medium text-secondary whitespace-nowrap">
                  {r.sem2}
                </div>
                <div class="text-center font-medium text-secondary whitespace-nowrap">
                  {r.sem3}
                </div>
                <div class="text-center font-medium text-secondary whitespace-nowrap">
                  {r.sem4}
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <p class="text-center mt-8 text-on-surface-variant text-sm italic">
        * Au-delà de 4 semaines, le remplissage sera facturé au tarif d'une pose
        complète.
      </p>

      {/* Dépose */}
      <div class="mt-16 grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div
          class="bg-surface-container-lowest p-8 rounded-xl border border-outline-variant/10 flex justify-between items-center"
        >
          <div>
            <h4 class="font-bold text-on-surface mb-1">Dépose</h4>
            <p class="text-xs text-on-surface-variant">
              Retrait de vos extensions actuelles
            </p>
          </div>
          <span class="text-secondary font-bold text-xl">10€</span>
        </div>
        <div
          class="bg-surface-container-lowest p-8 rounded-xl border border-outline-variant/10 flex justify-between items-center"
        >
          <div>
            <h4 class="font-bold text-on-surface mb-1">Dépose extérieure</h4>
            <p class="text-xs text-on-surface-variant">
              Extensions posées dans un autre institut
            </p>
          </div>
          <span class="text-secondary font-bold text-xl">15€</span>
        </div>
      </div>
    </div>
  </div>
</section>
