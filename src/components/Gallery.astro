---
interface BeforeAfter {
  before: string;
  after: string;
  alt: string;
  label: string;
  technique: string;
}

const comparisons: BeforeAfter[] = [
  {
    before: "/images/avant-1.jpg",
    after: "/images/apres-1.jpg",
    alt: "Avant/après pose cil à cil par Célia C., technicienne de cils à Rosières en Ardèche",
    label: "Cil à Cil",
    technique: "Effet naturel",
  },
  {
    before: "/images/avant-2.jpg",
    after: "/images/apres-2.jpg",
    alt: "Avant/après pose mixte extension de cils à Rosières (07260), Ardèche",
    label: "Mixte",
    technique: "Naturel & dense",
  },
  {
    before: "/images/avant-3.jpg",
    after: "/images/apres-3.jpg",
    alt: "Avant/après volume russe extension de cils par Célia C. à Rosières, Ardèche",
    label: "Volume Russe",
    technique: "Densité maximale",
  },
];
---

<section class="py-24 bg-surface" id="realisations">
  <div class="max-w-7xl mx-auto px-8">
    <div class="text-center mb-16" data-animate>
      <span
        class="text-secondary font-label text-xs tracking-[0.3em] uppercase mb-4 block font-semibold"
      >
        AVANT / APRÈS
      </span>
      <h2 class="font-headline text-4xl md:text-5xl text-on-surface mb-4">
        Mes réalisations
      </h2>
      <p
        class="text-on-surface-variant max-w-2xl mx-auto text-lg font-light leading-relaxed"
      >
        <span class="md:hidden">Touchez</span><span class="hidden md:inline"
          >Survolez</span
        > pour découvrir la transformation. Chaque pose est unique, adaptée à la forme
        de vos yeux.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8" data-stagger>
      {
        comparisons.map((item, i) => (
          <div class="polaroid-group" data-animate style={`--i:${i}`}>
            {/* Stacked polaroid container */}
            <div class="relative h-[420px] md:h-[480px]">
              {/* Before (back card) */}
              <div class="polaroid-before absolute inset-0 w-[88%] rounded-xl overflow-hidden shadow-lg shadow-on-surface/10 border border-outline-variant/10 bg-surface-container-lowest">
                <div class="h-full p-2.5 pb-14">
                  <img
                    src={item.before}
                    alt={`Avant - ${item.alt}`}
                    class="w-full h-full object-cover rounded-lg"
                    loading="lazy"
                  />
                </div>
                <span class="absolute bottom-4 left-5 text-xs font-label font-bold tracking-widest uppercase text-outline">
                  Avant
                </span>
              </div>

              {/* After (front card, overlapping) */}
              <div class="polaroid-after absolute inset-0 left-[12%] w-[88%] rounded-xl overflow-hidden shadow-xl shadow-on-surface/15 border border-outline-variant/10 bg-surface-container-lowest">
                <div class="h-full p-2.5 pb-14">
                  <img
                    src={item.after}
                    alt={`Après - ${item.alt}`}
                    class="w-full h-full object-cover rounded-lg"
                    loading="lazy"
                  />
                </div>
                <span class="absolute bottom-4 right-5 text-xs font-label font-bold tracking-widest uppercase text-primary">
                  Après
                </span>
                <span class="absolute bottom-4 left-5 material-symbols-outlined text-secondary text-base">
                  auto_awesome
                </span>
                <div class="polaroid-hint md:hidden absolute top-[72%] left-1/2 -translate-x-1/2 -translate-y-1/2 bg-on-surface/70 backdrop-blur-sm rounded-full pl-2.5 pr-3.5 py-1.5 text-[10px] font-label font-semibold uppercase tracking-widest text-on-primary inline-flex items-center gap-1.5 shadow-lg pointer-events-none">
                  <span class="material-symbols-outlined text-sm">
                    touch_app
                  </span>
                  Toucher
                </div>
              </div>
            </div>

            {/* Caption */}
            <div class="mt-5 text-center">
              <h3 class="font-headline text-xl text-on-surface">
                {item.label}
              </h3>
              <p class="text-sm text-on-surface-variant">{item.technique}</p>
            </div>
          </div>
        ))
      }
    </div>

    <div class="mt-14 text-center" data-animate>
      <a
        href="https://www.instagram.com/celiac_techniciennedecils07260/"
        target="_blank"
        rel="noopener noreferrer"
        class="text-primary font-bold hover:underline underline-offset-8 transition-all inline-flex items-center gap-2 group"
      >
        Voir plus sur Instagram
        <span
          class="material-symbols-outlined transition-transform group-hover:translate-x-1"
          >arrow_right_alt</span
        >
      </a>
    </div>
  </div>
</section>

<style>
  .polaroid-before {
    transform: rotate(-3deg) translateX(-4%);
    z-index: 1;
  }

  .polaroid-after {
    transform: rotate(2deg) translateX(4%);
    transition:
      transform 0.7s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 2;
  }

  /* States when swapped */
  .polaroid-group.is-swapped .polaroid-after {
    transform: rotate(-1deg) translateX(-4%) translateY(6px);
    box-shadow: 0 6px 16px -6px rgba(0, 0, 0, 0.06);
    z-index: 1;
  }

  @keyframes card-to-front {
    0% {
      transform: rotate(-3deg) translateX(-4%) translateY(0);
      z-index: 1;
    }
    40% {
      transform: rotate(0deg) translateX(-28%) translateY(-28px);
      z-index: 3;
    }
    100% {
      transform: rotate(2deg) translateX(8%) translateY(-6px);
      z-index: 3;
      box-shadow: 0 20px 40px -8px rgba(0, 0, 0, 0.16);
    }
  }

  @keyframes card-to-back {
    0% {
      transform: rotate(2deg) translateX(8%) translateY(-6px);
      z-index: 3;
      box-shadow: 0 20px 40px -8px rgba(0, 0, 0, 0.16);
    }
    40% {
      transform: rotate(0deg) translateX(-28%) translateY(-28px);
      z-index: 3;
    }
    100% {
      transform: rotate(-3deg) translateX(-4%) translateY(0);
      z-index: 1;
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    }
  }

  .polaroid-before.anim-in {
    animation: card-to-front 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .polaroid-before.anim-out {
    animation: card-to-back 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .polaroid-hint {
    transform: rotate(-4deg);
    transform-origin: center;
    animation: hint-pulse 2.4s ease-in-out infinite;
    transition: opacity 0.4s ease;
  }

  .polaroid-group.is-swapped .polaroid-hint,
  .polaroid-group.has-interacted .polaroid-hint {
    opacity: 0;
  }

  @keyframes hint-pulse {
    0%,
    100% {
      transform: rotate(-4deg) scale(1);
    }
    50% {
      transform: rotate(-4deg) scale(1.05);
    }
  }
</style>

<script>
  const isCoarsePointer = window.matchMedia("(hover: none)").matches;

  document.querySelectorAll(".polaroid-group").forEach((group) => {
    const before = group.querySelector(".polaroid-before") as HTMLElement;
    if (!before) return;

    const swap = () => {
      before.classList.remove("anim-out");
      before.classList.add("anim-in");
      group.classList.add("is-swapped");
    };

    const unswap = () => {
      before.classList.remove("anim-in");
      before.classList.add("anim-out");
      group.classList.remove("is-swapped");
    };

    if (isCoarsePointer) {
      group.addEventListener("click", () => {
        group.classList.add("has-interacted");
        if (group.classList.contains("is-swapped")) {
          unswap();
        } else {
          swap();
        }
      });
    } else {
      group.addEventListener("mouseenter", swap);
      group.addEventListener("mouseleave", unswap);
    }

    before.addEventListener("animationend", (e) => {
      if ((e as AnimationEvent).animationName === "card-to-back") {
        before.classList.remove("anim-out");
      }
    });
  });
</script>
