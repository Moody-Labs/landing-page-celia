---

<section class="py-24 bg-surface" id="realisations">
  <div class="max-w-7xl mx-auto px-8">
    <div class="text-center mb-16">
      <h2 class="font-headline text-4xl text-on-surface">Mes réalisations</h2>
      <p class="text-on-surface-variant mt-2">Un aperçu de mon travail au quotidien</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 grid-rows-2 gap-4 h-[800px] md:h-[600px]">
      {images.map((image) => (
        <div class:list={[image.class, 'relative overflow-hidden rounded-xl group']}>
          <img
            alt={image.alt}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            src={image.src}
          />
          {image.label && (
            <div class="absolute inset-0 bg-gradient-to-t from-on-surface/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-8">
              <span class="text-on-primary font-headline text-xl italic">{image.label}</span>
            </div>
          )}
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <a href="https://www.instagram.com/celiac_techniciennedecils07260/" target="_blank" rel="noopener noreferrer" class="text-primary font-bold hover:underline underline-offset-8 transition-all inline-flex items-center gap-2 group">
        Voir plus sur Instagram
        <span class="material-symbols-outlined transition-transform group-hover:translate-x-1">arrow_right_alt</span>
      </a>
    </div>
  </div>
</section>
